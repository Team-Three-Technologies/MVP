{
  "name": "dipreader-mvp-t3",
  "version": "0.0.1",
  "author": "Team Three Technologies (t3.unipd@gmail.com)",
  "description": "MVP del progetto C3 - DIPReader, realizzato dal gruppo 3, Team Three Technologies, corso di Ingegneria del Software 2025/2026 @ Università degli Studi di Padova.",
  "main": "dist/main/main/main.js",
  "scripts": {
    "clean:dist": "rimraf dist renderer/dist",
    "clean:cache": "rimraf renderer/.angular",
    "clean:modules:main": "rimraf node_modules",
    "clean:modules:renderer": "rimraf renderer/node_modules",
    "clean:modules:all": "rimraf node_modules renderer/node_modules",
    "clean:release": "rimraf release",
    "clean": "rimraf dist release node_modules renderer/.angular renderer/dist renderer/node_modules",
    "copy:migrations": "copyfiles -u 1 main/src/infrastructure/migrations/*.sql dist/main/main",
    "build:main": "tsc -p tsconfig.main.json && npm run copy:migrations",
    "build:renderer": "cd renderer && ng build --configuration production",
    "build": "npm run build:main && npm run build:renderer",
    "watch:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "cd renderer && ng serve",
    "dev:electron": "wait-on http://localhost:4200 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently --names \"ANGULAR,MAIN,ELECTRON\" --prefix-colors \"blue,cyan,yellow\" \"npm run dev:renderer\" \"npm run watch:main\" \"npm run copy:migrations && npm run dev:electron\"",
    "test:main": "vitest run --config vitest.main.config.ts",
    "test:main:ci": "vitest run --config vitest.main.config.ts --reporter=junit --outputFile=test-results/main.xml",
    "test:renderer": "cd renderer && ng test --watch=false",
    "test:renderer:ci": "cd renderer && ng test --watch=false",
    "test": "npm run test:main && npm run test:renderer",
    "test:ci": "npm run test:main:ci && npm run test:renderer:ci",
    "package": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "it.unipd.t3.dipreader-mvp",
    "productName": "DIPReader MVP - T3",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "dir",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "devDependencies": {
    "@swc/core": "^1.15.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node-7z": "^2.1.11",
    "concurrently": "^9.2.1",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.2",
    "electron-builder": "^26.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "better-sqlite3": "^12.6.2",
    "electron-is-dev": "^3.0.1",
    "fast-xml-parser": "^5.5.9",
    "node-7z": "^3.0.0",
    "reflect-metadata": "^0.2.2",
    "tslib": "^2.8.1",
    "tsyringe": "^4.10.0"
  }
}
