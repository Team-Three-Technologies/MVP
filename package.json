{
  "name": "dipreader-mvp-t3",
  "version": "0.0.1",
  "author": "Team Three Technologies (t3.unipd@gmail.com)",
  "description": "MVP del progetto C3 - DIPReader, realizzato dal gruppo 3, Team Three Technologies, corso di Ingegneria del Software 2025/2026 @ Università degli Studi di Padova.",
  "main": "dist/main/main/main.js",
  "scripts": {
    "clean:dist": "rimraf dist renderer/dist",
    "clean:cache": "rimraf renderer/.angular",
    "clean:cov": "rimraf coverage renderer/coverage",
    "clean:modules:main": "rimraf node_modules",
    "clean:modules:renderer": "rimraf renderer/node_modules",
    "clean:modules:all": "rimraf node_modules renderer/node_modules",
    "clean:release": "rimraf release",
    "clean": "rimraf dist release node_modules renderer/.angular renderer/dist renderer/node_modules",
    "copy:migrations": "copyfiles -u 1 main/src/infrastructure/database/migrations/*.sql dist/main/main",
    "build:main": "tsc -p tsconfig.main.json && npm run copy:migrations",
    "build:renderer": "cd renderer && ng build --configuration production",
    "build": "npm run build:main && npm run build:renderer",
    "watch:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "cd renderer && ng serve",
    "rebuild:main": "npm rebuild better-sqlite3",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "dev:electron": "npm run rebuild:electron && wait-on http://localhost:4200 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently --names \"ANGULAR,MAIN,ELECTRON\" --prefix-colors \"blue,cyan,yellow\" \"npm run dev:renderer\" \"npm run watch:main\" \"npm run copy:migrations && npm run dev:electron\"",
    "test:main": "npm run rebuild:main && vitest run --config vitest.main.config.ts",
    "test:main:cov": "vitest run --config vitest.main.config.ts --coverage",
    "test:renderer": "cd renderer && npm run test",
    "test:renderer:cov": "cd renderer && npm run test:cov",
    "test": "npm run test:main && npm run test:renderer",
    "test:cov": "npm run test:main:cov && npm run test:renderer:cov",
    "test:e2e": "npm run rebuild:electron && playwright test",
    "package": "npm run rebuild:electron && npm run build && electron-builder",
    "format:main": "prettier --write \"main/src/**/*.ts\" \"main/test/**/*.ts\" \"shared/**/*.ts\"",
    "format:renderer": "cd renderer && npm run format",
    "format": "npm run format:main && npm run format:renderer"
  },
  "build": {
    "appId": "it.unipd.t3.dipreader-mvp",
    "productName": "DIPReader MVP - T3",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "mac": {
      "target": "zip",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "devDependencies": {
    "@swc/core": "^1.15.18",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.1",
    "concurrently": "^9.2.1",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.2",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "electron-is-dev": "^3.0.1",
    "fast-xml-parser": "^5.5.9",
    "prettier": "^3.8.3",
    "reflect-metadata": "^0.2.2",
    "tslib": "^2.8.1",
    "tsyringe": "^4.10.0"
  }
}